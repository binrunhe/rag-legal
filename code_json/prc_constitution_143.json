        "content": "国务院行使下列职权：",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第九十条",
        "article_number": "第九十条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第三节　国务院"
        },
        "content": "国务院各部部长、各委员会主任负责本部门的工作；召集和主持部务会议或者委员会会议、委务会议，讨论决定本部门工作的重大问题。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第九十一条",
        "article_number": "第九十一条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第三节　国务院"
        },
        "content": "国务院设立审计机关，对国务院各部门和地方各级政府的财政收支，对国家的财政金融机构和企业事业组织的财务收支，进行审计监督。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第九十二条",
        "article_number": "第九十二条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第三节　国务院"
        },
        "content": "国务院对全国人民代表大会负责并报告工作；在全国人民代表大会闭会期间，对全国人民代表大会常务委员会负责并报告工作。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第九十三条",
        "article_number": "第九十三条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第四节　中央军事委员会"
        },
        "content": "中华人民共和国中央军事委员会领导全国武装力量。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第九十四条",
        "article_number": "第九十四条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第四节　中央军事委员会"
        },
        "content": "中央军事委员会主席对全国人民代表大会和全国人民代表大会常务委员会负责。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第九十五条",
        "article_number": "第九十五条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第五节　地方各级人民代表大会和地方各级人民政府"
        },
        "content": "省、直辖市、县、市、市辖区、乡、民族乡、镇设立人民代表大会和人民政府。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第九十六条",
        "article_number": "第九十六条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第五节　地方各级人民代表大会和地方各级人民政府"
        },
        "content": "地方各级人民代表大会是地方国家权力机关。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第九十七条",
        "article_number": "第九十七条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第五节　地方各级人民代表大会和地方各级人民政府"
        },
        "content": "省、直辖市、设区的市的人民代表大会代表由下一级的人民代表大会选举；县、不设区的市、市辖区、乡、民族乡、镇的人民代表大会代表由选民直接选举。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第九十八条",
        "article_number": "第九十八条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第五节　地方各级人民代表大会和地方各级人民政府"
        },
        "content": "地方各级人民代表大会每届任期五年。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第九十九条",
        "article_number": "第九十九条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第五节　地方各级人民代表大会和地方各级人民政府"
        },
        "content": "地方各级人民代表大会在本行政区域内，保证宪法、法律、行政法规的遵守和执行；依照法律规定的权限，通过和发布决议，审查和决定地方的经济建设、文化建设和公共事业建设的计划。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第一百条",
        "article_number": "第一百条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第五节　地方各级人民代表大会和地方各级人民政府"
        },
        "content": "省、直辖市的人民代表大会和它们的常务委员会，在不同宪法、法律、行政法规相抵触的前提下，可以制定地方性法规，报全国人民代表大会常务委员会备案。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第一百零一条",
        "article_number": "第一百零一条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第五节　地方各级人民代表大会和地方各级人民政府"
        },
        "content": "地方各级人民代表大会分别选举并且有权罢免本级人民政府的省长和副省长、市长和副市长、县长和副县长、区长和副区长、乡长和副乡长、镇长和副镇长。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第一百零二条",
        "article_number": "第一百零二条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第五节　地方各级人民代表大会和地方各级人民政府"
        },
        "content": "省、直辖市、设区的市的人民代表大会代表受原选举单位的监督；县、不设区的市、市辖区、乡、民族乡、镇的人民代表大会代表受选民的监督。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第一百零三条",
        "article_number": "第一百零三条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第五节　地方各级人民代表大会和地方各级人民政府"
        },
        "content": "县级以上的地方各级人民代表大会常务委员会由主任、副主任若干人和委员若干人组成，对本级人民代表大会负责并报告工作。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第一百零四条",
        "article_number": "第一百零四条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第五节　地方各级人民代表大会和地方各级人民政府"
        },
        "content": "县级以上的地方各级人民代表大会常务委员会讨论、决定本行政区域内各方面工作的重大事项；监督本级人民政府、监察委员会、人民法院和人民检察院的工作；撤销本级人民政府的不适当的决定和命令；撤销下一级人民代表大会的不适当的决议；依照法律规定的权限决定国家机关工作人员的任免；在本级人民代表大会闭会期间，罢免和补选上一级人民代表大会的个别代表。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第一百零五条",
        "article_number": "第一百零五条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第五节　地方各级人民代表大会和地方各级人民政府"
        },
        "content": "地方各级人民政府是地方各级国家权力机关的执行机关，是地方各级国家行政机关。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第一百零六条",
        "article_number": "第一百零六条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第五节　地方各级人民代表大会和地方各级人民政府"
        },
        "content": "地方各级人民政府每届任期同本级人民代表大会每届任期相同。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第一百零七条",
        "article_number": "第一百零七条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第五节　地方各级人民代表大会和地方各级人民政府"
        },
        "content": "县级以上地方各级人民政府依照法律规定的权限，管理本行政区域内的经济、教育、科学、文化、卫生、体育事业、城乡建设事业和财政、民政、公安、民族事务、司法行政、计划生育等行政工作，发布决定和命令，任免、培训、考核和奖惩行政工作人员。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第一百零八条",
        "article_number": "第一百零八条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第五节　地方各级人民代表大会和地方各级人民政府"
        },
        "content": "县级以上的地方各级人民政府领导所属各工作部门和下级人民政府的工作，有权改变或者撤销所属各工作部门和下级人民政府的不适当的决定。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第一百零九条",
        "article_number": "第一百零九条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第五节　地方各级人民代表大会和地方各级人民政府"
        },
        "content": "县级以上的地方各级人民政府设立审计机关。地方各级审计机关依照法律规定独立行使审计监督权，对本级人民政府和上一级审计机关负责。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第一百一十条",
        "article_number": "第一百一十条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第五节　地方各级人民代表大会和地方各级人民政府"
        },
        "content": "地方各级人民政府对本级人民代表大会负责并报告工作。县级以上的地方各级人民政府在本级人民代表大会闭会期间，对本级人民代表大会常务委员会负责并报告工作。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第一百一十一条",
        "article_number": "第一百一十一条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第五节　地方各级人民代表大会和地方各级人民政府"
        },
        "content": "城市和农村按居民居住地区设立的居民委员会或者村民委员会是基层群众性自治组织。居民委员会、村民委员会的主任、副主任和委员由居民选举。居民委员会、村民委员会同基层政权的相互关系由法律规定。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第一百一十二条",
        "article_number": "第一百一十二条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第六节　民族自治地方的自治机关"
        },
        "content": "民族自治地方的自治机关是自治区、自治州、自治县的人民代表大会和人民政府。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第一百一十三条",
        "article_number": "第一百一十三条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第六节　民族自治地方的自治机关"
        },
        "content": "自治区、自治州、自治县的人民代表大会中，除实行区域自治的民族的代表外，其他居住在本行政区域内的民族也应当有适当名额的代表。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第一百一十四条",
        "article_number": "第一百一十四条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第六节　民族自治地方的自治机关"
        },
        "content": "自治区主席、自治州州长、自治县县长由实行区域自治的民族的公民担任。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第一百一十五条",
        "article_number": "第一百一十五条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第六节　民族自治地方的自治机关"
        },
        "content": "自治区、自治州、自治县的自治机关行使宪法第三章第五节规定的地方国家机关的职权，同时依照宪法、民族区域自治法和其他法律规定的权限行使自治权，根据本地方实际情况贯彻执行国家的法律、政策。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第一百一十六条",
        "article_number": "第一百一十六条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第六节　民族自治地方的自治机关"
        },
        "content": "民族自治地方的人民代表大会有权依照当地民族的政治、经济和文化的特点，制定自治条例和单行条例。自治区的自治条例和单行条例，报全国人民代表大会常务委员会批准后生效。自治州、自治县的自治条例和单行条例，报省或者自治区的人民代表大会常务委员会批准后生效，并报全国人民代表大会常务委员会备案。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第一百一十七条",
        "article_number": "第一百一十七条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第六节　民族自治地方的自治机关"
        },
        "content": "民族自治地方的自治机关有管理地方财政的自治权。凡是依照国家财政体制属于民族自治地方的财政收入，都应当由民族自治地方的自治机关自主地安排使用。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第一百一十八条",
        "article_number": "第一百一十八条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第六节　民族自治地方的自治机关"
        },
        "content": "民族自治地方的自治机关在国家计划的指导下，自主地安排和管理地方性的经济建设事业。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第一百一十九条",
        "article_number": "第一百一十九条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第六节　民族自治地方的自治机关"
        },
        "content": "民族自治地方的自治机关自主地管理本地方的教育、科学、文化、卫生、体育事业，保护和整理民族的文化遗产，发展和繁荣民族文化。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第一百二十条",
        "article_number": "第一百二十条",
        "hierarchy": {
