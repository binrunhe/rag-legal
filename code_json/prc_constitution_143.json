[
    {
        "id": "PRC_Constitution_第一条",
        "article_number": "第一条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "中华人民共和国是工人阶级领导的、以工农联盟为基础的人民民主专政的社会主义国家。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第二条",
        "article_number": "第二条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "中华人民共和国的一切权力属于人民。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第三条",
        "article_number": "第三条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "中华人民共和国的国家机构实行民主集中制的原则。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第四条",
        "article_number": "第四条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "中华人民共和国各民族一律平等。国家保障各少数民族的合法的权利和利益，维护和发展各民族的平等团结互助和谐关系。禁止对任何民族的歧视和压迫，禁止破坏民族团结和制造民族分裂的行为。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第五条",
        "article_number": "第五条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "中华人民共和国实行依法治国，建设社会主义法治国家。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第六条",
        "article_number": "第六条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "中华人民共和国的社会主义经济制度的基础是生产资料的社会主义公有制，即全民所有制和劳动群众集体所有制。社会主义公有制消灭人剥削人的制度，实行各尽所能、按劳分配的原则。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第七条",
        "article_number": "第七条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "国有经济，即社会主义全民所有制经济，是国民经济中的主导力量。国家保障国有经济的巩固和发展。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第八条",
        "article_number": "第八条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "农村集体经济组织实行家庭承包经营为基础、统分结合的双层经营体制。农村中的生产、供销、信用、消费等各种形式的合作经济，是社会主义劳动群众集体所有制经济。参加农村集体经济组织的劳动者，有权在法律规定的范围内经营自留地、自留山、家庭副业和饲养自留畜。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第九条",
        "article_number": "第九条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "矿藏、水流、森林、山岭、草原、荒地、滩涂等自然资源，都属于国家所有，即全民所有；由法律规定属于集体所有的森林和山岭、草原、荒地、滩涂除外。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第十条",
        "article_number": "第十条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "城市的土地属于国家所有。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第十一条",
        "article_number": "第十一条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "在法律规定范围内的个体经济、私营经济等非公有制经济，是社会主义市场经济的重要组成部分。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第十二条",
        "article_number": "第十二条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "社会主义的公共财产神圣不可侵犯。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第十三条",
        "article_number": "第十三条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "公民的合法的私有财产不受侵犯。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第十四条",
        "article_number": "第十四条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "国家通过提高劳动者的积极性和技术水平，推广先进的科学技术，完善经济管理体制和企业经营管理制度，实行各种形式的社会主义责任制，改进劳动组织，以不断提高劳动生产率和经济效益，发展社会生产力。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第十五条",
        "article_number": "第十五条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "国家实行社会主义市场经济。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第十六条",
        "article_number": "第十六条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "国有企业在法律规定的范围内有权自主经营。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第十七条",
        "article_number": "第十七条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "集体经济组织在遵守有关法律的前提下，有独立进行经济活动的自主权。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第十八条",
        "article_number": "第十八条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "中华人民共和国允许外国的企业和其他经济组织或者个人依照中华人民共和国法律的规定在中国投资，同中国的企业或者其他经济组织进行各种形式的经济合作。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第十九条",
        "article_number": "第十九条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "国家发展社会主义的教育事业，提高全国人民的科学文化水平。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第二十条",
        "article_number": "第二十条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "国家发展自然科学和社会科学事业，普及科学和技术知识，奖励科学研究成果和技术发明创造。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第二十一条",
        "article_number": "第二十一条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "国家发展医疗卫生事业，发展现代医药和我国传统医药，鼓励和支持农村集体经济组织、国家企业事业组织和街道组织举办各种医疗卫生设施，开展群众性的卫生活动，保护人民健康。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第二十二条",
        "article_number": "第二十二条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "国家发展为人民服务、为社会主义服务的文学艺术事业、新闻广播电视事业、出版发行事业、图书馆博物馆文化馆和其他文化事业，开展群众性的文化活动。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第二十三条",
        "article_number": "第二十三条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "国家培养为社会主义服务的各种专业人才，扩大知识分子的队伍，创造条件，充分发挥他们在社会主义现代化建设中的作用。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第二十四条",
        "article_number": "第二十四条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "国家通过普及理想教育、道德教育、文化教育、纪律和法制教育，通过在城乡不同范围的群众中制定和执行各种守则、公约，加强社会主义精神文明的建设。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第二十五条",
        "article_number": "第二十五条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "国家推行计划生育，使人口的增长同经济和社会发展计划相适应。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第二十六条",
        "article_number": "第二十六条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "国家保护和改善生活环境和生态环境，防治污染和其他公害。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第二十七条",
        "article_number": "第二十七条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "一切国家机关实行精简的原则，实行工作责任制，实行工作人员的培训和考核制度，不断提高工作质量和工作效率，反对官僚主义。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第二十八条",
        "article_number": "第二十八条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "国家维护社会秩序，镇压叛国和其他危害国家安全的犯罪活动，制裁危害社会治安、破坏社会主义经济和其他犯罪的活动，惩办和改造犯罪分子。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第二十九条",
        "article_number": "第二十九条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "中华人民共和国的武装力量属于人民。它的任务是巩固国防，抵抗侵略，保卫祖国，保卫人民的和平劳动，参加国家建设事业，努力为人民服务。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第三十条",
        "article_number": "第三十条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "中华人民共和国的行政区域划分如下：",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第三十一条",
        "article_number": "第三十一条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "国家在必要时得设立特别行政区。在特别行政区内实行的制度按照具体情况由全国人民代表大会以法律规定。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第三十二条",
        "article_number": "第三十二条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第一章　总　　纲",
            "section": ""
        },
        "content": "中华人民共和国保护在中国境内的外国人的合法权利和利益，在中国境内的外国人必须遵守中华人民共和国的法律。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第三十三条",
        "article_number": "第三十三条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "凡具有中华人民共和国国籍的人都是中华人民共和国公民。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第三十四条",
        "article_number": "第三十四条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "中华人民共和国年满十八周岁的公民，不分民族、种族、性别、职业、家庭出身、宗教信仰、教育程度、财产状况、居住期限，都有选举权和被选举权；但是依照法律被剥夺政治权利的人除外。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第三十五条",
        "article_number": "第三十五条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "中华人民共和国公民有言论、出版、集会、结社、游行、示威的自由。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第三十六条",
        "article_number": "第三十六条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "中华人民共和国公民有宗教信仰自由。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第三十七条",
        "article_number": "第三十七条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "中华人民共和国公民的人身自由不受侵犯。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第三十八条",
        "article_number": "第三十八条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "中华人民共和国公民的人格尊严不受侵犯。禁止用任何方法对公民进行侮辱、诽谤和诬告陷害。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第三十九条",
        "article_number": "第三十九条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "中华人民共和国公民的住宅不受侵犯。禁止非法搜查或者非法侵入公民的住宅。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第四十条",
        "article_number": "第四十条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "中华人民共和国公民的通信自由和通信秘密受法律的保护。除因国家安全或者追查刑事犯罪的需要，由公安机关或者检察机关依照法律规定的程序对通信进行检查外，任何组织或者个人不得以任何理由侵犯公民的通信自由和通信秘密。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第四十一条",
        "article_number": "第四十一条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "中华人民共和国公民对于任何国家机关和国家工作人员，有提出批评和建议的权利；对于任何国家机关和国家工作人员的违法失职行为，有向有关国家机关提出申诉、控告或者检举的权利，但是不得捏造或者歪曲事实进行诬告陷害。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第四十二条",
        "article_number": "第四十二条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "中华人民共和国公民有劳动的权利和义务。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第四十三条",
        "article_number": "第四十三条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "中华人民共和国劳动者有休息的权利。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第四十四条",
        "article_number": "第四十四条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "国家依照法律规定实行企业事业组织的职工和国家机关工作人员的退休制度。退休人员的生活受到国家和社会的保障。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第四十五条",
        "article_number": "第四十五条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "中华人民共和国公民在年老、疾病或者丧失劳动能力的情况下，有从国家和社会获得物质帮助的权利。国家发展为公民享受这些权利所需要的社会保险、社会救济和医疗卫生事业。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第四十六条",
        "article_number": "第四十六条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "中华人民共和国公民有受教育的权利和义务。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第四十七条",
        "article_number": "第四十七条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "中华人民共和国公民有进行科学研究、文学艺术创作和其他文化活动的自由。国家对于从事教育、科学、技术、文学、艺术和其他文化事业的公民的有益于人民的创造性工作，给以鼓励和帮助。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第四十八条",
        "article_number": "第四十八条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "中华人民共和国妇女在政治的、经济的、文化的、社会的和家庭的生活等各方面享有同男子平等的权利。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第四十九条",
        "article_number": "第四十九条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "婚姻、家庭、母亲和儿童受国家的保护。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第五十条",
        "article_number": "第五十条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "中华人民共和国保护华侨的正当的权利和利益，保护归侨和侨眷的合法的权利和利益。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第五十一条",
        "article_number": "第五十一条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "中华人民共和国公民在行使自由和权利的时候，不得损害国家的、社会的、集体的利益和其他公民的合法的自由和权利。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第五十二条",
        "article_number": "第五十二条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "中华人民共和国公民有维护国家统一和全国各民族团结的义务。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第五十三条",
        "article_number": "第五十三条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "中华人民共和国公民必须遵守宪法和法律，保守国家秘密，爱护公共财产，遵守劳动纪律，遵守公共秩序，尊重社会公德。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第五十四条",
        "article_number": "第五十四条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "中华人民共和国公民有维护祖国的安全、荣誉和利益的义务，不得有危害祖国的安全、荣誉和利益的行为。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第五十五条",
        "article_number": "第五十五条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "保卫祖国、抵抗侵略是中华人民共和国每一个公民的神圣职责。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第五十六条",
        "article_number": "第五十六条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第二章　公民的基本权利和义务",
            "section": ""
        },
        "content": "中华人民共和国公民有依照法律纳税的义务。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第五十七条",
        "article_number": "第五十七条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第一节　全国人民代表大会"
        },
        "content": "中华人民共和国全国人民代表大会是最高国家权力机关。它的常设机关是全国人民代表大会常务委员会。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第五十八条",
        "article_number": "第五十八条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第一节　全国人民代表大会"
        },
        "content": "全国人民代表大会和全国人民代表大会常务委员会行使国家立法权。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第五十九条",
        "article_number": "第五十九条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第一节　全国人民代表大会"
        },
        "content": "全国人民代表大会由省、自治区、直辖市、特别行政区和军队选出的代表组成。各少数民族都应当有适当名额的代表。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第六十条",
        "article_number": "第六十条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第一节　全国人民代表大会"
        },
        "content": "全国人民代表大会每届任期五年。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第六十一条",
        "article_number": "第六十一条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第一节　全国人民代表大会"
        },
        "content": "全国人民代表大会会议每年举行一次，由全国人民代表大会常务委员会召集。如果全国人民代表大会常务委员会认为必要，或者有五分之一以上的全国人民代表大会代表提议，可以临时召集全国人民代表大会会议。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第六十二条",
        "article_number": "第六十二条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第一节　全国人民代表大会"
        },
        "content": "全国人民代表大会行使下列职权：",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第六十三条",
        "article_number": "第六十三条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第一节　全国人民代表大会"
        },
        "content": "全国人民代表大会有权罢免下列人员：",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第六十四条",
        "article_number": "第六十四条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第一节　全国人民代表大会"
        },
        "content": "宪法的修改，由全国人民代表大会常务委员会或者五分之一以上的全国人民代表大会代表提议，并由全国人民代表大会以全体代表的三分之二以上的多数通过。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第六十五条",
        "article_number": "第六十五条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第一节　全国人民代表大会"
        },
        "content": "全国人民代表大会常务委员会由下列人员组成：",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第六十六条",
        "article_number": "第六十六条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第一节　全国人民代表大会"
        },
        "content": "全国人民代表大会常务委员会每届任期同全国人民代表大会每届任期相同，它行使职权到下届全国人民代表大会选出新的常务委员会为止。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第六十七条",
        "article_number": "第六十七条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第一节　全国人民代表大会"
        },
        "content": "全国人民代表大会常务委员会行使下列职权：",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第六十八条",
        "article_number": "第六十八条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第一节　全国人民代表大会"
        },
        "content": "全国人民代表大会常务委员会委员长主持全国人民代表大会常务委员会的工作，召集全国人民代表大会常务委员会会议。副委员长、秘书长协助委员长工作。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第六十九条",
        "article_number": "第六十九条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第一节　全国人民代表大会"
        },
        "content": "全国人民代表大会常务委员会对全国人民代表大会负责并报告工作。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第七十条",
        "article_number": "第七十条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第一节　全国人民代表大会"
        },
        "content": "全国人民代表大会设立民族委员会、宪法和法律委员会、财政经济委员会、教育科学文化卫生委员会、外事委员会、华侨委员会和其他需要设立的专门委员会。在全国人民代表大会闭会期间，各专门委员会受全国人民代表大会常务委员会的领导。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第七十一条",
        "article_number": "第七十一条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第一节　全国人民代表大会"
        },
        "content": "全国人民代表大会和全国人民代表大会常务委员会认为必要的时候，可以组织关于特定问题的调查委员会，并且根据调查委员会的报告，作出相应的决议。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第七十二条",
        "article_number": "第七十二条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第一节　全国人民代表大会"
        },
        "content": "全国人民代表大会代表和全国人民代表大会常务委员会组成人员，有权依照法律规定的程序分别提出属于全国人民代表大会和全国人民代表大会常务委员会职权范围内的议案。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第七十三条",
        "article_number": "第七十三条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第一节　全国人民代表大会"
        },
        "content": "全国人民代表大会代表在全国人民代表大会开会期间，全国人民代表大会常务委员会组成人员在常务委员会开会期间，有权依照法律规定的程序提出对国务院或者国务院各部、各委员会的质询案。受质询的机关必须负责答复。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第七十四条",
        "article_number": "第七十四条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第一节　全国人民代表大会"
        },
        "content": "全国人民代表大会代表，非经全国人民代表大会会议主席团许可，在全国人民代表大会闭会期间非经全国人民代表大会常务委员会许可，不受逮捕或者刑事审判。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第七十五条",
        "article_number": "第七十五条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第一节　全国人民代表大会"
        },
        "content": "全国人民代表大会代表在全国人民代表大会各种会议上的发言和表决，不受法律追究。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第七十六条",
        "article_number": "第七十六条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第一节　全国人民代表大会"
        },
        "content": "全国人民代表大会代表必须模范地遵守宪法和法律，保守国家秘密，并且在自己参加的生产、工作和社会活动中，协助宪法和法律的实施。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第七十七条",
        "article_number": "第七十七条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第一节　全国人民代表大会"
        },
        "content": "全国人民代表大会代表受原选举单位的监督。原选举单位有权依照法律规定的程序罢免本单位选出的代表。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第七十八条",
        "article_number": "第七十八条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第一节　全国人民代表大会"
        },
        "content": "全国人民代表大会和全国人民代表大会常务委员会的组织和工作程序由法律规定。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第七十九条",
        "article_number": "第七十九条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第二节　中华人民共和国主席"
        },
        "content": "中华人民共和国主席、副主席由全国人民代表大会选举。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第八十条",
        "article_number": "第八十条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第二节　中华人民共和国主席"
        },
        "content": "中华人民共和国主席根据全国人民代表大会的决定和全国人民代表大会常务委员会的决定，公布法律，任免国务院总理、副总理、国务委员、各部部长、各委员会主任、审计长、秘书长，授予国家的勋章和荣誉称号，发布特赦令，宣布进入紧急状态，宣布战争状态，发布动员令。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第八十一条",
        "article_number": "第八十一条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第二节　中华人民共和国主席"
        },
        "content": "中华人民共和国主席代表中华人民共和国，进行国事活动，接受外国使节；根据全国人民代表大会常务委员会的决定，派遣和召回驻外全权代表，批准和废除同外国缔结的条约和重要协定。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第八十二条",
        "article_number": "第八十二条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第二节　中华人民共和国主席"
        },
        "content": "中华人民共和国副主席协助主席工作。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第八十三条",
        "article_number": "第八十三条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第二节　中华人民共和国主席"
        },
        "content": "中华人民共和国主席、副主席行使职权到下届全国人民代表大会选出的主席、副主席就职为止。",
        "source": "中华人民共和国宪法"
    },
    {
        "id": "PRC_Constitution_第八十四条",
        "article_number": "第八十四条",
        "hierarchy": {
            "book": "",
            "subbook": "",
            "chapter": "第三章　国家机构",
            "section": "第二节　中华人民共和国主席"
        },
        "content": "中华人民共和国主席缺位的时候，由副主席继任主席的职位。",
        "source": "中华人民共和国宪法"
    },
    {
