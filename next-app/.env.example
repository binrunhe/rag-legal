# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# Optional: public backend API base URL for frontend requests.
# Example: https://api.hehe051104.me
# If empty, frontend will fall back to relative paths (same-origin /api/*).
NEXT_PUBLIC_API_BASE_URL=

# Local backend defaults for the Python/FastAPI auth flow.
NEXT_PUBLIC_BASE_PATH=
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# SMTP configuration for welcome emails and password reset codes.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=****
SMTP_PASSWORD=****
SMTP_FROM=
SMTP_USE_SSL=true
SMTP_USE_TLS=false

# Backend reset-code cache. Redis is preferred; if empty, the Python backend will use in-memory TTL storage.
REDIS_URL=
RESET_CODE_SECRET=
RESET_CODE_EXPIRE_MINUTES=5
RESET_CODE_RESEND_INTERVAL_SECONDS=60

# Admin assignment controls.
ADMIN_EMAILS=
ADMIN_INVITE_CODE=

# FastAPI CORS origins for local/dev frontend access.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
